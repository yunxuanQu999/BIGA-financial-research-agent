# 复制此文件为 .env，填入你自己的 Key

# ===== LLM（必填）=====
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://www.dmxapi.cn/v1    # 或 https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro-guan

# ===== 新闻搜索（必填）=====
TAVILY_API_KEY=your_tavily_api_key_here

# ===== 飞书推送（必填）=====
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_here

# ===== 以下可留空 =====
TUSHARE_TOKEN=
LLAMA_CLOUD_API_KEY=
E2B_API_KEY=
MEM0_API_KEY=           # app.mem0.ai 获取，云端记忆跨设备持久化
QDRANT_URL=             # 留空则自动使用本地文件模式，无需 Docker
LANGSMITH_API_KEY=      # smith.langchain.com 获取，设置后自动追踪所有 LLM 调用和 Agent 运行轨迹
LANGSMITH_PROJECT=biga-financial-agent
