# 忽略虚拟环境
venv/
env/

# 忽略环境变量和密钥
.env

# 忽略 Python 缓存文件
__pycache__/
*.pyc
.pytest_cache/

# 忽略本地生成的数据和图表（可选，看你想不想传图表）
output/charts/*
data/reports/*
!output/charts/.gitkeep
!data/reports/.gitkeep

# 忽略 Mac 系统文件
.DS_Store

# 本地 Qdrant 向量数据库
/tmp/mem0_qdrant/

# 日志
*.log
evals/results/

# IDE
.idea/
.vscode/
